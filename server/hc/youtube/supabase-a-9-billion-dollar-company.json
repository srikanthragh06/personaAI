        "offset": 183840,
        "lang": "hi"
    },
    {
        "text": "कर सकते हो। कहने का मतलब यह है कि आप",
        "duration": 4320,
        "offset": 186080,
        "lang": "hi"
    },
    {
        "text": "अपनी एप्लीकेशन पूरी तरह से रिएक्ट में",
        "duration": 3921,
        "offset": 188159,
        "lang": "hi"
    },
    {
        "text": "लिख सकते हो। हां जी। नेक्स्ट इयर्स भी",
        "duration": 3520,
        "offset": 190400,
        "lang": "hi"
    },
    {
        "text": "नहीं। पूरी तरह से आप अपनी एप्लीकेशन",
        "duration": 4239,
        "offset": 192080,
        "lang": "hi"
    },
    {
        "text": "रिएक्ट के अंदर लिख सकते हो। आप कभी भी इन",
        "duration": 4239,
        "offset": 193920,
        "lang": "hi"
    },
    {
        "text": "सर्विज से बात नहीं करते। आप बात करते हो",
        "duration": 4161,
        "offset": 196319,
        "lang": "hi"
    },
    {
        "text": "इन बैक एंड एज अ सर्विस से और यह आपसे बात",
        "duration": 5281,
        "offset": 198159,
        "lang": "hi"
    },
    {
        "text": "करती है वापस। आपको सिर्फ एक एपीआई सीखनी",
        "duration": 4880,
        "offset": 200480,
        "lang": "hi"
    },
    {
        "text": "होती है कि कैसे इनकी एपीआई से मैं बात",
        "duration": 3760,
        "offset": 203440,
        "lang": "hi"
    },
    {
        "text": "करूंगा और दैट्स इट। इन्हीं के थ्रू सारा",
