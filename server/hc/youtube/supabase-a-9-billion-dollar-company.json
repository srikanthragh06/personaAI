        "offset": 528959,
        "lang": "hi"
    },
    {
        "text": "ऑब्वियस सी बात है यह कंसर्न सबको रहता",
        "duration": 3679,
        "offset": 531600,
        "lang": "hi"
    },
    {
        "text": "है। मुझे भी रहता है। हमेशा ही रहता है।",
        "duration": 4800,
        "offset": 533200,
        "lang": "hi"
    },
    {
        "text": "लेकिन जो पोस्टग्रेस आपके साथ करता है या",
        "duration": 4961,
        "offset": 535279,
        "lang": "hi"
    },
    {
        "text": "फिर आपको यह सुपर बेस जो आपको फीचर देता",
        "duration": 4160,
        "offset": 538000,
        "lang": "hi"
    },
    {
        "text": "है वो ये रो लेवल सिक्योरिटी आपको खुद से",
        "duration": 4400,
        "offset": 540240,
        "lang": "hi"
    },
    {
        "text": "कस्टमाइज लिखने को देता है। इसके अंदर आप",
        "duration": 5359,
        "offset": 542160,
        "lang": "hi"
    },
    {
        "text": "क्या कर सकते हो कि हर एक डेटाबेस की रो",
        "duration": 5360,
        "offset": 544640,
        "lang": "hi"
    },
    {
        "text": "के ऊपर आप पॉलिसीज लगा सकते हो कि कौन सी",
        "duration": 5601,
        "offset": 547519,
        "lang": "hi"
    },
    {
        "text": "रो कौन रीड कर सकता है? क्या एनोनिमस यूजर",
        "duration": 6320,
        "offset": 550000,
        "lang": "hi"
    },
    {
        "text": "एक रो रीड कर सकता है? क्या लॉक्ड इन यूजर",
        "duration": 5440,
        "offset": 553120,
        "lang": "hi"
    },
    {
        "text": "दूसरे की रोज़ रीड कर सकता है या सिर्फ खुद",
        "duration": 4560,
        "offset": 556320,
        "lang": "hi"
    },
    {
        "text": "की ही रो रीड कर सकता है या फिर दूसरे की",
        "duration": 4640,
        "offset": 558560,
        "lang": "hi"
    },
    {
        "text": "रोज़ रीड कर सकता है पर उसमें राइट नहीं कर",
        "duration": 4880,
        "offset": 560880,
        "lang": "hi"
    },
    {
        "text": "सकता है। कितनी परमिशंस क्या है इसके बारे",
