        "offset": 473919,
        "lang": "hi"
    },
    {
        "text": "इसको रो सिक्योरिटी पॉलिसीज भी बोलते हैं।",
        "duration": 4240,
        "offset": 476720,
        "lang": "hi"
    },
    {
        "text": "आपको कई जगह सर्च करने को मिलेगा",
        "duration": 4160,
        "offset": 478960,
        "lang": "hi"
    },
    {
        "text": "पोस्टग्रेस रो लेवल सिक्योरिटी। मैं",
        "duration": 4239,
        "offset": 480960,
        "lang": "hi"
    },
    {
        "text": "आरएलएस ही बोलता हूं। कई जगह इसको रो",
        "duration": 4079,
        "offset": 483120,
        "lang": "hi"
    },
    {
        "text": "सिक्योरिटी भी बोला जाता है। दोनों एक ही",
        "duration": 3840,
        "offset": 485199,
        "lang": "hi"
    },
    {
        "text": "चीजें हैं। अब देखो ये करता क्या है? मैं",
        "duration": 3440,
        "offset": 487199,
        "lang": "hi"
    },
    {
        "text": "आपको यहां से एक डेफिनेशन दिखाता हूं छोटी",
        "duration": 3201,
        "offset": 489039,
        "lang": "hi"
    },
    {
        "text": "सी। उससे आपको बड़ा इजीली समझ में आ",
        "duration": 3680,
        "offset": 490639,
        "lang": "hi"
    },
    {
        "text": "जाएगा। अब सैडली इसका डार्क मोड नहीं है।",
        "duration": 4480,
        "offset": 492240,
        "lang": "hi"
    },
    {
        "text": "तो रो लेवल सिक्योरिटी इज़ अ पोस्ट ग्रेस",
        "duration": 4320,
        "offset": 494319,
        "lang": "hi"
    },
    {
        "text": "सिक्योरिटी फीचर प्रोवाइडेड बाय द ओपन",
        "duration": 3919,
        "offset": 496720,
        "lang": "hi"
    },
    {
        "text": "सोर्स पोस्ट ग्रेस डेटाबेस। ठीक है जी।",
        "duration": 3761,
        "offset": 498639,
        "lang": "hi"
    },
    {
        "text": "कहानी समझ में आई कि पोस्टग्रेस आपको ये",
        "duration": 4321,
        "offset": 500639,
        "lang": "hi"
    },
    {
        "text": "फीचर प्रोवाइड करता है। इट अलाउज़ डेटाबेस",
        "duration": 4799,
        "offset": 502400,
        "lang": "hi"
    },
    {
        "text": "एडमिनिस्ट्रेटर टू डिफाइन पॉलिसीज़ टू",
        "duration": 4880,
        "offset": 504960,
        "lang": "hi"
    },
    {
        "text": "कंट्रोल हाउ स्पेसिफिक रो ऑफ़ डेटा",
        "duration": 5520,
        "offset": 507199,
        "lang": "hi"
    },
    {
        "text": "डिस्प्ले एंड ऑपरेट फॉर वन और मोर मोर",
        "duration": 5199,
        "offset": 509840,
        "lang": "hi"
    },
    {
        "text": "यूजर रोल। अब देखिए सबसे बड़ी बात क्या",
        "duration": 4000,
        "offset": 512719,
        "lang": "hi"
    },
    {
        "text": "आती है? ऐसी सर्विज को जैसे ही आप यूज",
        "duration": 3120,
        "offset": 515039,
        "lang": "hi"
    },
    {
        "text": "करते हो और मैं आपको बोलता हूं कि आप",
        "duration": 4000,
        "offset": 516719,
        "lang": "hi"
    },
    {
        "text": "रिएक्ट से डायरेक्ट डेटाबेस से बात करोगे",
