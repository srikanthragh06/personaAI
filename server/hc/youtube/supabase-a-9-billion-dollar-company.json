        "offset": 571360,
        "lang": "hi"
    },
    {
        "text": "लेवल सिक्योरिटी का है। अगर आप कमेंट्स",
        "duration": 3279,
        "offset": 573120,
        "lang": "hi"
    },
    {
        "text": "में बोलेंगे तो हम एक प्रॉपर्ली डेडिकेटेड",
        "duration": 4000,
        "offset": 574560,
        "lang": "hi"
    },
    {
        "text": "क्रैश कोर्स या एटलीस्ट एक डिस्कशन गाइड",
        "duration": 4641,
        "offset": 576399,
        "lang": "hi"
    },
    {
        "text": "तो रखेंगे ही कि किस तरह से रोल लेवल",
        "duration": 4240,
        "offset": 578560,
        "lang": "hi"
    },
    {
        "text": "सिक्योरिटीज पे बात की जाती है और क्या",
        "duration": 3520,
        "offset": 581040,
        "lang": "hi"
    },
    {
        "text": "होता है। तो आप बताइएगा मुझे कमेंट सेक्शन",
        "duration": 3520,
        "offset": 582800,
        "lang": "hi"
    },
    {
        "text": "में अगर आपका मन है तो उस पे भी एक डिटेल",
        "duration": 4480,
        "offset": 584560,
        "lang": "hi"
    },
    {
        "text": "डिस्कशन करेंगे। बट सबसे इजी है कि आप इस",
        "duration": 6480,
        "offset": 586320,
        "lang": "hi"
    },
    {
        "text": "यूआरएल पे जाइएगा। आई थिंक सटोरी",
        "duration": 7600,
        "offset": 589040,
        "lang": "hi"
    },
    {
        "text": "अ कॉमनव्ट कंपनी satोorरी",
        "duration": 6320,
        "offset": 592800,
        "lang": "hi"
    },
    {
        "text": "वैसे मत समझिएगा। यह एक्चुअली में हो सकता",
        "duration": 5360,
        "offset": 596640,
        "lang": "hi"
    },
    {
        "text": "है जापानीज़ कंपनी हो। बट यहां पर बड़ा ही",
        "duration": 4560,
        "offset": 599120,
        "lang": "hi"
    },
    {
        "text": "अच्छा आर्टिकल है। पूरा यह रॉ लेवल",
        "duration": 3200,
        "offset": 602000,
        "lang": "hi"
    },
    {
        "text": "सिक्योरिटीज की पॉलिसी क्या होती है?",
        "duration": 3360,
        "offset": 603680,
        "lang": "hi"
    },
    {
        "text": "पॉलिसी सेलेक्टिव कैसे होती है? कैसे क्या",
        "duration": 3199,
        "offset": 605200,
        "lang": "hi"
    },
    {
        "text": "करते हैं? इन्होंने काफी अच्छा दे रखा है।",
        "duration": 3120,
        "offset": 607040,
        "lang": "hi"
    },
    {
        "text": "कभी हम भी और ईजी बना के इसका एग्जांपल",
        "duration": 3841,
        "offset": 608399,
        "lang": "hi"
    },
    {
        "text": "देखेंगे। बट समझने वाली और सबसे",
        "duration": 4239,
        "offset": 610160,
        "lang": "hi"
    },
    {
        "text": "इंटरेस्टिंग बात ये है कि इन जैसी सर्विज",
        "duration": 5279,
        "offset": 612240,
        "lang": "hi"
    },
    {
        "text": "को जैसे सुपर बेस है इनके साथ काम करने से",
        "duration": 5201,
        "offset": 614399,
        "lang": "hi"
    },
    {
        "text": "इनके साथ पढ़ने से आपको डेटाबेस के बारे",
        "duration": 4000,
        "offset": 617519,
        "lang": "hi"
    },
    {
        "text": "में और जानने को मिलता है। स्पेशली रो",
        "duration": 3520,
        "offset": 619600,
        "lang": "hi"
    },
    {
        "text": "लेवल सिक्योरिटी के बारे में जानने को",
        "duration": 4320,
        "offset": 621519,
        "lang": "hi"
    },
    {
        "text": "मिलता है। इनफैक्ट जो सुपर बेस के",
        "duration": 5120,
        "offset": 623120,
        "lang": "hi"
    },
    {
        "text": "फाउंडर्स हैं उन्होंने बहुत काम करा है",
        "duration": 5440,
        "offset": 625839,
        "lang": "hi"
    },
    {
        "text": "ऑथेंटिकेशन और ऑथराइजेशन के ऊपर भी। एक",
        "duration": 4960,
        "offset": 628240,
        "lang": "hi"
    },
    {
        "text": "वीडियो और मैं डेडिकेटली लेके आऊंगा जहां",
        "duration": 3921,
        "offset": 631279,
        "lang": "hi"
    },
    {
        "text": "पे हम सिर्फ और सिर्फ इनके ऑथ पे बात",
        "duration": 3840,
        "offset": 633200,
        "lang": "hi"
    },
    {
        "text": "करेंगे कि किस तरह से पूरा मैट्रिक्स",
