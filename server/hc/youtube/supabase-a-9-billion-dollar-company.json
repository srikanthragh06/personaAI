[
    {
        "text": "इंटरनेट का वह टाइम मैं हमेशा मिस करूंगा",
        "duration": 5360,
        "offset": 880,
        "lang": "hi"
    },
    {
        "text": "जब मैं किसी भी प्रोडक्ट के बारे में",
        "duration": 5441,
        "offset": 4319,
        "lang": "hi"
    },
    {
        "text": "बेखौफ सीधा आकर बात कर सकता था। आजकल",
        "duration": 5200,
        "offset": 6240,
        "lang": "hi"
    },
    {
        "text": "थोड़ा सोचना पड़ता है। खैर इस वीडियो में",
        "duration": 3680,
        "offset": 9760,
        "lang": "hi"
    },
    {
        "text": "तो नहीं सोच रहा हूं। आजकल थोड़ा सोचना",
        "duration": 3440,
        "offset": 11440,
        "lang": "hi"
    },
    {
        "text": "पड़ता है क्योंकि किसी भी प्रोडक्ट के",
        "duration": 3040,
        "offset": 13440,
        "lang": "hi"
    },
    {
        "text": "बारे में आप बात करोगे सबसे पहले आता है",
        "duration": 3920,
        "offset": 14880,
        "lang": "hi"
    },
    {
        "text": "अरे यह वीडियो स्पों्सर्ड है क्या? अगर हो",
        "duration": 4480,
        "offset": 16480,
        "lang": "hi"
    },
    {
        "text": "तो मैं चीख-चीख के बोलना चाहूंगा। हां जी",
        "duration": 4639,
        "offset": 18800,
        "lang": "hi"
    },
    {
        "text": "स्पों्सर्ड है। एंड थैंक यू सो मच। बट",
        "duration": 4319,
        "offset": 20960,
        "lang": "hi"
    },
    {
        "text": "वीडियो स्पॉन्सर्ड भी नहीं है। और फिर भी",
        "duration": 2961,
        "offset": 23439,
        "lang": "hi"
    },
    {
        "text": "मैं एक प्रोडक्ट के बारे में बात कर रहा",
        "duration": 3281,
        "offset": 25279,
        "lang": "hi"
    },
    {
        "text": "हूं क्योंकि मैं मैं बात करना चाहता हूं",
        "duration": 3760,
        "offset": 26400,
        "lang": "hi"
    },
    {
        "text": "उसके बारे में। मुझे अच्छा लगता है",
        "duration": 3280,
        "offset": 28560,
        "lang": "hi"
    },
    {
        "text": "प्रोडक्ट एंड आई थिंक अगर मैं उसके बारे",
        "duration": 3520,
        "offset": 30160,
        "lang": "hi"
    },
    {
        "text": "में मेरा थॉट प्रोसेस आपको दूंगा मे बी",
        "duration": 3600,
        "offset": 31840,
        "lang": "hi"
    },
    {
        "text": "किसी प्रोजेक्ट में मे बी किसी स्टार्टअप",
        "duration": 3840,
        "offset": 33680,
        "lang": "hi"
    },
    {
        "text": "में कंपनी में आपको भी यह प्रोडक्ट कहीं",
        "duration": 4080,
        "offset": 35440,
        "lang": "hi"
    },
    {
        "text": "ना कहीं हेल्प कर सकता है तो मैंने सोचा",
        "duration": 4400,
        "offset": 37520,
        "lang": "hi"
    },
    {
        "text": "कब तक ही डरते रहेंगे निकालते हैं इस डर",
        "duration": 3920,
        "offset": 39520,
        "lang": "hi"
    },
    {
        "text": "को और जितने भी प्रोडक्ट्स के बारे में",
        "duration": 3520,
        "offset": 41920,
        "lang": "hi"
    },
    {
        "text": "मैं बात करना चाहता हूं विदाउट एनी",
        "duration": 3840,
        "offset": 43440,
        "lang": "hi"
    },
    {
        "text": "स्पॉनसरशिप मैं खुल के उनके बारे में बात",
        "duration": 4000,
        "offset": 45440,
        "lang": "hi"
    },
    {
        "text": "कर सकता हूं थोड़ी बुराई भी करेंगे अच्छाई",
        "duration": 4160,
        "offset": 47280,
        "lang": "hi"
    },
    {
        "text": "भी करेंगे जो भी मुझे मेरे फीलिंग्स हैं",
        "duration": 3840,
        "offset": 49440,
        "lang": "hi"
    },
    {
        "text": "मेरे थॉट प्रोसेस है वो सब आपके सामने में",
        "duration": 4080,
        "offset": 51440,
        "lang": "hi"
    },
    {
        "text": "बताएंगे तो ऐसा ही एक प्रोडक्ट है सुपर",
        "duration": 4160,
        "offset": 53280,
        "lang": "hi"
    },
    {
        "text": "बेस और भी ऐसे बहुत सारे प्रोडक्ट हैं जिन",
        "duration": 3280,
        "offset": 55520,
        "lang": "hi"
    },
    {
        "text": "पे वीडियोस आने वाले हैं बहुत सारी ऐसी",
        "duration": 2880,
        "offset": 57440,
        "lang": "hi"
    },
    {
        "text": "ऐसी कंपोनेंट लाइब्रेरीज, यूआई",
        "duration": 3759,
        "offset": 58800,
        "lang": "hi"
    },
    {
        "text": "लाइब्रेरीज, टूल्स, टेक्नोलॉजीज़ हैं जिनके",
        "duration": 4000,
        "offset": 60320,
        "lang": "hi"
    },
    {
        "text": "बारे में मैं खुल के बात करना चाहता हूं।",
        "duration": 3761,
        "offset": 62559,
        "lang": "hi"
    },
    {
        "text": "पर अब नहीं डरेंगे। अब बात करेंगे उसके",
        "duration": 3680,
        "offset": 64320,
        "lang": "hi"
    },
    {
        "text": "बारे में। अगर कोई कमेंट्स में बोलता भी",
        "duration": 3600,
        "offset": 66320,
        "lang": "hi"
    },
    {
        "text": "है कि यह वीडियो तो स्पों्सर्ड है। बोलने",
        "duration": 4240,
        "offset": 68000,
        "lang": "hi"
    },
    {
        "text": "दीजिए। नहीं है। अगर आपको बोलना ही है तो",
        "duration": 4960,
        "offset": 69920,
        "lang": "hi"
    },
    {
        "text": "प्लीज Twitter पे जाके बोलिएगा कि हां जी",
        "duration": 4800,
        "offset": 72240,
        "lang": "hi"
    },
    {
        "text": "प्लीज स्पोंसर करो हितेश को क्योंकि हितेश",
        "duration": 3440,
        "offset": 74880,
        "lang": "hi"
    },
    {
        "text": "आपके प्लेटफार्म के बारे में बात कर रहा",
        "duration": 3040,
        "offset": 77040,
        "lang": "hi"
    },
    {
        "text": "था। तो एटलीस्ट मैं खुल के बोल पाऊं कि",
        "duration": 4240,
        "offset": 78320,
        "lang": "hi"
    },
    {
        "text": "हां जी इस इस कंपनी ने स्पोंसर किया मुझे।",
        "duration": 4800,
        "offset": 80080,
        "lang": "hi"
    },
    {
        "text": "खैर उन सब बातों को साइड में रखते हैं।",
        "duration": 4960,
        "offset": 82560,
        "lang": "hi"
    },
    {
        "text": "हां जी कैसे हैं आप सभी? स्वागत है आप सभी",
        "duration": 5279,
        "offset": 84880,
        "lang": "hi"
    },
    {
        "text": "का चाय और कोट पे और आज हम एक थोड़ा सा नई",
        "duration": 4400,
        "offset": 87520,
        "lang": "hi"
    },
    {
        "text": "टेक्नोलॉजी के बारे में डिस्कस करेंगे। नई",
        "duration": 4000,
        "offset": 90159,
        "lang": "hi"
    },
    {
        "text": "तो नया है नया तो नहीं है यह प्रोडक्ट बट",
        "duration": 4080,
        "offset": 91920,
        "lang": "hi"
    },
    {
        "text": "इसके एक थोड़ा सा ओवरव्यू आपको दूंगा ताकि",
        "duration": 3761,
        "offset": 94159,
        "lang": "hi"
    },
    {
        "text": "आप इसके ट्रू पोटेंशियल के बारे में जान",
        "duration": 4400,
        "offset": 96000,
        "lang": "hi"
    },
    {
        "text": "पाएं और इसको शायद यूज़ भी कर पाएं अगर",
        "duration": 4559,
        "offset": 97920,
        "lang": "hi"
    },
    {
        "text": "आपका मन है तो यूज़ करने का। हां जी",
        "duration": 4240,
        "offset": 100400,
        "lang": "hi"
    },
    {
        "text": "प्रोडक्ट का नाम है हमारे सुपर बेस और इन",
        "duration": 3680,
        "offset": 102479,
        "lang": "hi"
    },
    {
        "text": "केस अगर आपने नहीं सुना है तो यह आपके",
        "duration": 3600,
        "offset": 104640,
        "lang": "hi"
    },
    {
        "text": "हैकेथों्स के लिए बहुत ही यूज़फुल हो सकता",
