        "offset": 123680,
        "lang": "hi"
    },
    {
        "text": "में हैं। आपने फायरब का नाम सुना होगा।",
        "duration": 4400,
        "offset": 125520,
        "lang": "hi"
    },
    {
        "text": "फायरब भी इसी कैटेगरी के अंदर आता है।",
        "duration": 4241,
        "offset": 127759,
        "lang": "hi"
    },
    {
        "text": "आपने एपराइट का भी नाम सुना होगा। वह भी",
        "duration": 4080,
        "offset": 129920,
        "lang": "hi"
    },
    {
        "text": "इसी कैटेगरी के अंदर आता है। इनको",
        "duration": 3920,
        "offset": 132000,
        "lang": "hi"
    },
    {
        "text": "एक्चुअली में जो बोला जाता है वह बोला",
        "duration": 5680,
        "offset": 134000,
        "lang": "hi"
    },
    {
        "text": "जाता है बैस बैक एंड एज ए सर्विस। तो हुआ",
        "duration": 5440,
        "offset": 135920,
        "lang": "hi"
    },
    {
        "text": "क्या कि बहुत सारे लोग कुछ ना कुछ",
        "duration": 3680,
        "offset": 139680,
        "lang": "hi"
    },
    {
        "text": "एप्लीकेशन बिल्ड करना चाहते थे और उन",
        "duration": 4160,
        "offset": 141360,
        "lang": "hi"
    },
    {
        "text": "एप्लीकेशन के अंदर कुछ जो प्रोसेससेस है",
        "duration": 4959,
        "offset": 143360,
        "lang": "hi"
    },
    {
        "text": "वो हमेशा से सेम ही रहती हैं। जैसे कि ऑथ",
        "duration": 4880,
        "offset": 145520,
        "lang": "hi"
    },
    {
        "text": "आपको Google लॉग इन करना है, ईमेल लॉग इन",
        "duration": 4560,
        "offset": 148319,
        "lang": "hi"
    },
    {
        "text": "करना है, फॉरगॉट पासवर्ड करना है। ये सब",
        "duration": 5199,
        "offset": 150400,
        "lang": "hi"
    },
    {
        "text": "बड़ा ही कॉमन है। हर एक एप्लीकेशन को कुछ",
        "duration": 5121,
        "offset": 152879,
        "lang": "hi"
    },
    {
        "text": "ना कुछ डीबी लगता ही है। कुछ ना कुछ",
        "duration": 4640,
        "offset": 155599,
        "lang": "hi"
    },
    {
        "text": "स्टोरेज लगता ही लगता है। अब वो स्टोरेज",
        "duration": 4640,
        "offset": 158000,
        "lang": "hi"
    },
    {
        "text": "एडब्ल्यूएस से लो, डिजिटल ओशन से लो, किसी",
