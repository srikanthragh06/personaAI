[
    {
        "text": "ऑलराइट। सो, हे एवरीवन, वेलकम बैक। वेलकम",
        "duration": 4160,
        "offset": 80,
        "lang": "hi"
    },
    {
        "text": "बैक टु अनदर एक्साइटिंग वीडियो एंड इन दिस",
        "duration": 5120,
        "offset": 2080,
        "lang": "hi"
    },
    {
        "text": "वीडियो, हम बात करेंगे अबाउट वीओआईपी दैट",
        "duration": 5600,
        "offset": 4240,
        "lang": "hi"
    },
    {
        "text": "स्टैंड्स फॉर वॉइस ओवर इंटरनेट प्रोटोकॉल।",
        "duration": 4640,
        "offset": 7200,
        "lang": "hi"
    },
    {
        "text": "सो, इस वीडियो के अंदर एक हाई लेवल डिज़ाइन",
        "duration": 4000,
        "offset": 9840,
        "lang": "hi"
    },
    {
        "text": "और एक सिस्टम डिज़ाइन को समझेंगे दैट एक",
        "duration": 4400,
        "offset": 11840,
        "lang": "hi"
    },
    {
        "text": "वॉइस ओवर इंटरनेट प्रोटोकॉल क्या होता है?",
        "duration": 4480,
        "offset": 13840,
        "lang": "hi"
    },
    {
        "text": "एंड हाउ डज़ दिस वर्क एंड इसके अंदर",
        "duration": 4720,
        "offset": 16240,
        "lang": "hi"
    },
    {
        "text": "कौन-कौन से और प्रोटोकॉल्स आर इंक्लूडेड।",
        "duration": 4320,
        "offset": 18320,
        "lang": "hi"
    },
    {
        "text": "सो, विथ दैट, लेट्स स्टार्ट विद द वीडियो।",
        "duration": 3680,
        "offset": 20960,
        "lang": "hi"
    },
    {
        "text": "सो, यह एक ब्लॉग पेज है फ्रॉम द क्लाउड",
        "duration": 4240,
        "offset": 22640,
        "lang": "hi"
    },
    {
        "text": "फ्लेयर। एंड वीओआईपी की पहले बात करते",
        "duration": 4240,
        "offset": 24640,
        "lang": "hi"
    },
    {
        "text": "हैं। दैट एक वीओआईपी वॉइस ओवर इंटरनेट",
        "duration": 3840,
        "offset": 26880,
        "lang": "hi"
    },
    {
        "text": "प्रोटोकॉल होता क्या है? देखो जब भी आप",
        "duration": 4160,
        "offset": 28880,
        "lang": "hi"
    },
    {
        "text": "किसी को फोन कॉल करते हो यू यूज़ योर सिम",
        "duration": 4080,
        "offset": 30720,
        "lang": "hi"
    },
    {
        "text": "राइट? आपके पास एक नेटवर्क प्रोवाइडर होता",
        "duration": 3679,
        "offset": 33040,
        "lang": "hi"
    },
    {
        "text": "है लाइक Airtel हो सकता है, Jio हो सकता",
        "duration": 4480,
        "offset": 34800,
        "lang": "hi"
    },
    {
        "text": "है। एंड आप जो बात करते हो वो सेल्यूलर",
        "duration": 4481,
        "offset": 36719,
        "lang": "hi"
    },
    {
        "text": "नेटवर्क के ऊपर करते हो। बेसिकली जो ये",
        "duration": 4320,
        "offset": 39280,
        "lang": "hi"
    },
    {
        "text": "आपके नेटवर्क्स होते हैं आप इनके सेल्यूलर",
        "duration": 5199,
        "offset": 41200,
        "lang": "hi"
    },
    {
        "text": "को यूज़ करते हो टू ट्रांसफॉर्म योर वॉइस",
        "duration": 5439,
        "offset": 43600,
        "lang": "hi"
    },
    {
        "text": "इंटू एन एनालॉग थिंग एंड देन ट्रांसफर इट",
        "duration": 5041,
        "offset": 46399,
        "lang": "hi"
    },
    {
        "text": "ऑन दी वायर एंड सेंड इट टू द अदर यूजर। बट",
        "duration": 4401,
        "offset": 49039,
        "lang": "hi"
    },
    {
        "text": "वॉइस ओवर इंटरनेट प्रोटोकॉल के अंदर आप ये",
        "duration": 4000,
        "offset": 51440,
        "lang": "hi"
    },
    {
        "text": "सेल्यूलर नेटवर्क्स को यूज़ नहीं करते हो।",
        "duration": 4480,
        "offset": 53440,
        "lang": "hi"
    },
    {
        "text": "यू एक्चुअली यूज़ योर इंटरनेट। जिस इंटरनेट",
        "duration": 4400,
        "offset": 55440,
        "lang": "hi"
    },
    {
        "text": "पे अभी आप ये वीडियो को देख रहे हो, जिस",
        "duration": 3760,
        "offset": 57920,
        "lang": "hi"
    },
    {
        "text": "इंटरनेट के ऊपर आप वीडियो कॉल्स करते हो,",
        "duration": 3519,
        "offset": 59840,
        "lang": "hi"
    },
    {
        "text": "उसी इंटरनेट को हम यूज़ करते हैं टू",
        "duration": 3839,
        "offset": 61680,
        "lang": "hi"
    },
    {
        "text": "ट्रांसफर द वॉइस। अब इसका बेनिफिट क्या",
        "duration": 3921,
        "offset": 63359,
        "lang": "hi"
    },
    {
        "text": "है? नंबर वन यू आर यूजिंग द इंटरनेट। तो",
        "duration": 3521,
        "offset": 65519,
        "lang": "hi"
    },
    {
        "text": "आपके पास ज्यादा कैपेबिलिटीज़ होती है,",
        "duration": 3680,
        "offset": 67280,
        "lang": "hi"
    },
    {
        "text": "ज्यादा स्मूथ एक्सपीरियंस होता है। एंड यू",
        "duration": 3759,
        "offset": 69040,
        "lang": "hi"
    },
    {
        "text": "कैन इवन डू लाइक यू नो वीडियो कॉलिंग्स",
        "duration": 4080,
        "offset": 70960,
        "lang": "hi"
    },
    {
        "text": "एंड ऑल। तो अगर आपने कभी नोटिस किया होगा",
        "duration": 4881,
        "offset": 72799,
        "lang": "hi"
    },
    {
        "text": "अगर आप किसी को WhatsApp कॉल करते हो तो",
        "duration": 4719,
        "offset": 75040,
        "lang": "hi"
    },
    {
        "text": "दे साउंड क्लेरिटी इज़ एक्चुअली बेटर राइट",
        "duration": 4000,
        "offset": 77680,
        "lang": "hi"
    },
    {
        "text": "रादर देन द सेल्यूलर नेटवर्क तो ये होता",
        "duration": 3921,
        "offset": 79759,
        "lang": "hi"
    },
    {
        "text": "है आपका वीआयूआईपी तो आपके टीम्स की कॉल",
        "duration": 5920,
        "offset": 81680,
        "lang": "hi"
    },
    {
        "text": "स्लैक कॉल आपके अंदर आपके जो ये WhatsApp",
        "duration": 6320,
        "offset": 83680,
        "lang": "hi"
    },
    {
        "text": "कॉल्स होती हैं दे ऑल यूज़ वीआईपी बट ये",
        "duration": 4080,
        "offset": 87600,
        "lang": "hi"
    },
    {
        "text": "वीयूआईपी काम कैसे करता है? क्या-क्या",
        "duration": 3280,
        "offset": 90000,
        "lang": "hi"
    },
    {
        "text": "प्रोटोकॉल्स इंक्लूडेड है? तो वो हम बात",
        "duration": 3600,
        "offset": 91680,
        "lang": "hi"
    },
    {
        "text": "करते हैं इस वीडियो के अंदर। सो विथ दैट",
        "duration": 4159,
        "offset": 93280,
        "lang": "hi"
    },
    {
        "text": "लेट्स स्टार्ट वन। सो वीआईपी दैट इज़ वॉइस",
        "duration": 3839,
        "offset": 95280,
        "lang": "hi"
    },
    {
        "text": "ओवर इंटरनेट प्रोटोकॉल इज़ अ मेथड फॉर",
        "duration": 4881,
        "offset": 97439,
        "lang": "hi"
    },
    {
        "text": "मेकिंग टेलीफोन कॉल्स ओवर दी इंटरनेट।",
        "duration": 5201,
        "offset": 99119,
        "lang": "hi"
    },
    {
        "text": "दैट्स द होल थिंग। सो, अनलाइक द ओल्ड",
        "duration": 4479,
        "offset": 102320,
        "lang": "hi"
    },
    {
        "text": "लैंडलाइन टेलीफ़ोन सिस्टम, द इंटरनेट वाज़",
        "duration": 5360,
        "offset": 104320,
        "lang": "hi"
    },
    {
        "text": "नॉट डिज़ाइन टू कैरी ऑडियो सिग्नल्स इन",
        "duration": 5041,
        "offset": 106799,
        "lang": "hi"
    },
    {
        "text": "रियल टाइम बिटवीन टू कनेक्टेड पर्संस। सो,",
        "duration": 4640,
        "offset": 109680,
        "lang": "hi"
    },
    {
        "text": "दिस इज़ द मेन थिंग। देखो, जब हम लैंडलाइन",
        "duration": 3919,
        "offset": 111840,
        "lang": "hi"
    },
    {
        "text": "की बात करते हैं, तो यू रिमेंबर वहां पर",
        "duration": 3280,
        "offset": 114320,
        "lang": "hi"
    },
    {
        "text": "एक पोर्ट होता था, इथरनेट जैसा एक छोटा",
        "duration": 3441,
        "offset": 115759,
        "lang": "hi"
    },
    {
        "text": "पोर्ट होता था जिसको हम टेलीफ़ोन पोर्ट",
        "duration": 3839,
        "offset": 117600,
        "lang": "hi"
    },
    {
        "text": "कहते थे। तो उसके ऊपर आपकी पूरी वॉइसेस जो",
        "duration": 4239,
        "offset": 119200,
        "lang": "hi"
    },
    {
        "text": "होती थी वो ट्रांसफर होती थी। बिकॉज़",
        "duration": 4720,
        "offset": 121439,
        "lang": "hi"
    },
    {
        "text": "इंटरनेट जो था जो स्पेसिफिकली वो डिज़ नहीं",
        "duration": 4481,
        "offset": 123439,
        "lang": "hi"
    },
    {
        "text": "था कि मैं आपके ऑडियो सिग्नल्स को",
        "duration": 3841,
        "offset": 126159,
        "lang": "hi"
    },
    {
        "text": "ट्रांसफर कर सकूं। उतनी स्पीड नहीं थी,",
        "duration": 4240,
        "offset": 127920,
        "lang": "hi"
    },
    {
        "text": "उतनी लेटेंसी ऑप्टिमाइजेशनंस नहीं थी।",
        "duration": 4160,
        "offset": 130000,
        "lang": "hi"
    },
    {
        "text": "रियल टाइमनेस वाज़ मिसिंग। स्पेशलाइज़",
        "duration": 4320,
        "offset": 132160,
        "lang": "hi"
    },
    {
        "text": "टेक्नोलॉजीज़ एंड प्रोटोकॉल्स हैव टू बी",
        "duration": 4960,
        "offset": 134160,
        "lang": "hi"
    },
    {
        "text": "कंस्ट्रक्टेड टू मेक इट पॉसिबल। और ये जो",
        "duration": 4160,
        "offset": 136480,
        "lang": "hi"
    },
    {
        "text": "टेक्नोलॉजीज़ एंड प्रोटोकॉल्स की हम बात कर",
        "duration": 3839,
        "offset": 139120,
        "lang": "hi"
    },
    {
        "text": "रहे हैं दैट इज़ बेसिकली व्हाट इज़ वॉइप। तो",
        "duration": 4640,
        "offset": 140640,
        "lang": "hi"
    },
    {
        "text": "वॉइप खुद में एक प्रोटोकॉल नहीं है। वॉइप",
        "duration": 4081,
        "offset": 142959,
        "lang": "hi"
    },
    {
        "text": "क्या है? एक्चुअली में बहुत सारी और",
        "duration": 3920,
        "offset": 145280,
        "lang": "hi"
    },
    {
        "text": "प्रोटोकॉल्स को मिलाकर। ठीक है? वो जो हम",
        "duration": 4400,
        "offset": 147040,
        "lang": "hi"
    },
    {
        "text": "नीचे बात करेंगे इसी वीडियो के अंदर उसको",
        "duration": 4319,
        "offset": 149200,
        "lang": "hi"
    },
    {
        "text": "इन्होंने वॉइप बोला। दैट ऑल कंप्राइ्स",
        "duration": 5519,
        "offset": 151440,
        "lang": "hi"
    },
    {
        "text": "वॉइप। टुडे वॉइप इज़ अ हाइली एफिशिएंट। आई",
        "duration": 5440,
        "offset": 153519,
        "lang": "hi"
    },
    {
        "text": "डोंट नो इसको वॉइप कहना चाहिए या वीआईपी",
        "duration": 3920,
        "offset": 156959,
        "lang": "hi"
    },
    {
        "text": "कहना चाहिए। बट इट्स वन ऑन द सेम थिंग वब",
        "duration": 4000,
        "offset": 158959,
        "lang": "hi"
    },
    {
        "text": "और वीआईपी। एक्चुअली मैं जिस लास्ट कंपनी",
        "duration": 3921,
        "offset": 160879,
        "lang": "hi"
    },
    {
        "text": "में काम करता था वहां पर हमने वीआईपी के",
        "duration": 4161,
        "offset": 162959,
        "lang": "hi"
    },
    {
        "text": "ऊपर काफी काम किया था यूजिंग टलियो एज अ",
        "duration": 4240,
        "offset": 164800,
        "lang": "hi"
    },
    {
        "text": "सर्विस। तो वहां पर हर कोई वॉइप कहता था",
        "duration": 3280,
        "offset": 167120,
        "lang": "hi"
    },
    {
        "text": "इसको। तो आई थिंक दैट्स द रीज़न आई एम",
        "duration": 3279,
        "offset": 169040,
        "lang": "hi"
    },
    {
        "text": "कॉलिंग इट एज व बट आई यूज़्ड टू कॉल इट एज",
        "duration": 4400,
        "offset": 170400,
        "lang": "hi"
    },
    {
        "text": "वीआईपी। इज़ अ हाइली एफिशिएंट मेथड फॉर बोथ",
        "duration": 4721,
        "offset": 172319,
        "lang": "hi"
    },
    {
        "text": "ऑडियो एंड वीडियो रियल टाइम कम्युनिकेशंस।",
        "duration": 3680,
        "offset": 174800,
        "lang": "hi"
    },
    {
        "text": "ठीक है? सो दिस इज़ बेसिकली व्हाट वी आर",
        "duration": 3120,
        "offset": 177040,
        "lang": "hi"
    },
    {
        "text": "गोइंग टू सी। तो अगर हम यहां पे थोड़ा नीचे",
        "duration": 4960,
        "offset": 178480,
        "lang": "hi"
    },
    {
        "text": "चलते हैं तो यह एक पेज है। इसके अंदर एक",
        "duration": 6400,
        "offset": 180160,
        "lang": "hi"
    },
    {
        "text": "इंप्लीमेंटेशन है लाइ ऑफ़ दिस वी वॉइस ओवर",
        "duration": 5040,
        "offset": 183440,
        "lang": "hi"
    },
    {
        "text": "इंटरनेट प्रोटोकॉल एंड ये बहुत अच्छा",
        "duration": 3920,
        "offset": 186560,
        "lang": "hi"
    },
    {
        "text": "आर्टिकल है। अगर आपको अंडरस्टैंड करना है",
        "duration": 4240,
        "offset": 188480,
        "lang": "hi"
    },
    {
        "text": "कि सच में एक वॉइस ओवर इंटरनेट प्रोटोकॉल",
        "duration": 3839,
        "offset": 190480,
        "lang": "hi"
    },
    {
        "text": "काम कैसे करता है? ठीक है? तो थोड़ा सा हम",
        "duration": 4159,
        "offset": 192720,
        "lang": "hi"
    },
    {
        "text": "यहां से पढ़ते हैं। तो हमें एंड गोल क्या",
        "duration": 4401,
        "offset": 194319,
        "lang": "hi"
    },
    {
        "text": "है? अगर हम डिज़ाइन की बात करें तो हमारा",
        "duration": 4321,
        "offset": 196879,
        "lang": "hi"
    },
    {
        "text": "जो है वो एंड गोल क्या है? द एंड गोल इज़",
        "duration": 5599,
        "offset": 198720,
        "lang": "hi"
    },
    {
        "text": "नंबर वन वी नीड अ वे टू पिक अप द फोन। अगर",
        "duration": 6080,
        "offset": 201200,
        "lang": "hi"
    },
    {
        "text": "लेट्स से मेरे इस फोन ने वीओआईपी के ऊपर",
        "duration": 5361,
        "offset": 204319,
        "lang": "hi"
    },
    {
        "text": "किसी को कॉल किया तो देयर शुड बी अ वे कि",
        "duration": 4400,
        "offset": 207280,
        "lang": "hi"
